  <ItemGroup>
    <PackageReference Include="FastEndpoints.Testing" />
    <PackageReference Include="Testcontainers.PostgreSql" />
    <PackageReference Include="xunit.v3.mtp-v2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Source\NotesWeb\NotesWeb.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Features\ToDo\" />
    <Folder Include="Features\ToDo\ToDLists\" />
