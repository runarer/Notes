    <Folder Include="Features\ToDo\ToDLists\DeleteList\" />
    <Folder Include="Features\ToDo\ToDLists\GetLists\" />
    <Folder Include="Features\ToDo\ToDLists\RenameList\" />
    <Folder Include="Features\ToDo\ToDoItems\" />
    <Folder Include="Features\ToDo\ToDoItems\CompleteToDoItem\" />
    <Folder Include="Features\ToDo\ToDoItems\CreateToDoItem\" />
    <Folder Include="Features\ToDo\ToDoItems\DeleteToDoItem\" />
    <Folder Include="Features\ToDo\ToDoItems\GetList\" />
    <Folder Include="Features\ToDo\ToDoItems\MoveToDoItem\" />
    <Folder Include="Features\ToDo\ToDoItems\RenameToDoItem\" />
    <Folder Include="Features\Users\Login\" />
